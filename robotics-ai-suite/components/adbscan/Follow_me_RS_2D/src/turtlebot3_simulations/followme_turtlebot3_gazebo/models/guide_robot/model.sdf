        <geometry><box><size>0.066 0.005 0.075</size></box></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      <visual name="l13"><pose> 0.035 0.135 0.0375 0 0 0</pose>
        <geometry><box><size>0.066 0.005 0.075</size></box></geometry>
